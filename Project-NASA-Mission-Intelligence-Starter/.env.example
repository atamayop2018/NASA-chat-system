OPENAI_API_KEY=voc-556339427126677498335769ddb0f5cec5b1.48435936

# Point every OpenAI client at the Vocareum proxy instead of api.openai.com.
# Leave unset (or set to https://api.openai.com/v1) to talk to OpenAI directly.
OPENAI_BASE_URL=https://openai.vocareum.com/v1

